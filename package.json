{
  "name": "aussie-deal-hub",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "vitest --config vitest.workspace.ts --watch packages/config/src/env.test.ts",
    "release:bundle": "node scripts/release-bundle.mjs",
    "runtime:backup": "node scripts/runtime-backup.mjs",
    "runtime:restore": "node scripts/runtime-restore.mjs",
    "runtime:verify": "node scripts/runtime-verify.mjs",
    "smoke:container-health": "node scripts/check-compose-health.mjs",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "smoke:readiness": "node scripts/smoke-readiness.mjs",
    "test": "vitest run --config vitest.workspace.ts",
    "test:db": "node scripts/test-db.mjs",
    "verify": "pnpm build && pnpm test"
  },
  "devDependencies": {
    "jsdom": "^26.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
