generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Source {
  id         String   @id @default(cuid())
  name       String
  sourceType String
  baseUrl    String   @unique
  fetchMethod String  @default("html")
  pollIntervalMinutes Int @default(60)
  trustScore Int      @default(50)
  language   String   @default("en")
  enabled    Boolean  @default(true)
  pollCount  Int      @default(0)
  lastPolledAt DateTime?
  lastPollStatus String?
  lastPollMessage String?
  lastLeadCreatedAt DateTime?
  leads      Lead[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Lead {
  id             String           @id @default(cuid())
  sourceId       String
  originalTitle  String
  originalUrl    String
  canonicalUrl   String
  snippet        String
  merchant       String?
  sourceScore    Int?
  sourceSnapshot String?
  reviewStatus   String           @default("pending")
  aiConfidence   Int?
  riskLabels     String[]
  localizedHints String[]
  source         Source           @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  deal           Deal?
  reviewDraft    LeadReviewDraft?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([sourceId, reviewStatus])
  @@index([canonicalUrl])
}

model Deal {
  id              String       @id @default(cuid())
  leadId          String       @unique
  merchant        String
  category        String
  currentPrice    Decimal
  originalPrice   Decimal?
  discountPercent Int?
  couponCode      String?
  affiliateUrl    String
  status          String       @default("draft")
  locales         DealLocale[]
  lead            Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model DealLocale {
  id             String   @id @default(cuid())
  dealId         String
  locale         String
  slug           String   @unique
  title          String
  summary        String
  bodyMarkdown   String
  seoTitle       String
  seoDescription String
  deal           Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, locale])
}

model LeadReviewDraft {
  id           String                @id @default(cuid())
  leadId       String                @unique
  category     String
  confidence   Int
  riskLabels   String[]              @default([])
  tags         String[]              @default([])
  featuredSlot String                @default("")
  publishAt    String
  publish      Boolean               @default(false)
  lead         Lead                  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  locales      LeadReviewDraftLocale[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model LeadReviewDraftLocale {
  id            String          @id @default(cuid())
  reviewDraftId String
  locale        String
  title         String
  summary       String
  reviewDraft   LeadReviewDraft @relation(fields: [reviewDraftId], references: [id], onDelete: Cascade)

  @@unique([reviewDraftId, locale])
}

model Favorite {
  normalizedEmail String
  dealSlug        String
  createdAt       DateTime @default(now())

  @@id([normalizedEmail, dealSlug])
  @@index([normalizedEmail])
}

model EmailDigestSubscription {
  normalizedEmail String   @id
  locale          String   @default("en")
  frequency       String   @default("daily")
  categories      String[] @default([])
  lastSentAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MerchantCatalog {
  id              String   @id
  name            String
  activeDeals     Int      @default(0)
  primaryCategory String   @default("Unassigned")
  status          String   @default("Draft")
  owner           String   @default("Admin catalog")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TagCatalog {
  id           String   @id
  name         String
  slug         String   @unique
  visibleDeals Int      @default(0)
  localization String   @default("Needs localization")
  owner        String   @default("Admin catalog")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PriceSnapshot {
  id         String   @id @default(cuid())
  dealSlug   String
  label      String
  merchant   String
  price      Decimal
  observedAt DateTime
  createdAt  DateTime @default(now())

  @@index([dealSlug, observedAt])
}
